rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Nur eingeloggte User in ihrem eigenen Firmware-Ordner
    // Lesen ist sowieso über signed Download-URL möglich (für ESP)
    match /users/{userId}/firmware/{file=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024  // max 5 MB
                   && request.resource.contentType.matches('application/.*');
    }
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
