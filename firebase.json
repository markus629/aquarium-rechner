{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      "firestore.indexes.json",
      "**/.*",
      "**/node_modules/**",
      "README.md",
      "LICENSE",
      "*.bak",
      "*.backup.html",
      ".github/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "redirects": [
      { "source": "/dosier", "destination": "/kalk", "type": 301 },
      { "source": "/dosier/firestore-store.js", "destination": "/kalk/firestore-store.js", "type": 301 },
      { "source": "/dosier/index.html", "destination": "/kalk/", "type": 301 },
      { "source": "/dosier/:file", "destination": "/kalk/:file", "type": 301 }
    ],
    "headers": [
      {
        "source": "**/*.@(html|js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
